// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

model Channel {
  id           String               @id @default(cuid())
  name         String               @unique
  description  String?
  createdById  String?
  createdBy    User?                @relation("ChannelsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  memberships  ChannelMembership[]
  messages     FeedMessage[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ChannelMembership {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, channelId])
  @@index([channelId])
  @@index([userId])
}

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  role      Role       @default(STUDENT)
  channelMemberships ChannelMembership[]
  createdChannels    Channel[] @relation("ChannelsCreated")
  votes            Vote[]
  questions        Question[]
  questionReplies  QuestionReply[]
  feedPosts         GimnazijaFeedPost[]
  feedLikes         GimnazijaFeedLike[]
  feedComments      GimnazijaFeedComment[]
  feedMessages      FeedMessage[]
  notifications     Notification[] @relation("ReceivedNotifications")
  issuedNotifications Notification[] @relation("IssuedNotifications")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

enum NotificationType {
  REPLY
  LIKE
  COMMENT
  RESOLVED
  ADMIN_ANSWER
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  link        String?          // Link to the content (e.g., /pitanja#id)
  isRead      Boolean          @default(false)
  
  // The user who receives the notification
  userId      String
  user        User             @relation("ReceivedNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  // The user who triggered the notification (e.g., the one who liked)
  issuerId    String?
  issuer      User?            @relation("IssuedNotifications", fields: [issuerId], references: [id], onDelete: SetNull)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  mediaUrl  String?  // URL for image or video
  mediaType String?  // "IMAGE" or "VIDEO"
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rule {
  id          String   @id @default(cuid())
  title       String
  description String
  mediaUrl    String?
  mediaType   String?
  status      String   @default("ACTIVE") // ACTIVE, AMENDMENT_PROPOSED, DEPRECATED
  votes       Vote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ruleId    String
  rule      Rule     @relation(fields: [ruleId], references: [id])
  value     Boolean  // true for Yes/New, false for No/Keep
  createdAt DateTime @default(now())

  @@unique([userId, ruleId])
}

model Question {
  id         String          @id @default(cuid())
  content    String
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  answer     String?
  isResolved Boolean         @default(false)
  replies    QuestionReply[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model QuestionReply {
  id         String   @id @default(cuid())
  content    String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model GimnazijaFeedPost {
  id        String   @id @default(cuid())
  content   String
  mediaUrl  String?
  mediaType String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  likes     GimnazijaFeedLike[]
  comments  GimnazijaFeedComment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GimnazijaFeedLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      GimnazijaFeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
}

model GimnazijaFeedComment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      GimnazijaFeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeedMessage {
  id        String   @id @default(cuid())
  content   String
  mediaUrl  String?
  mediaType String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
}
